DB_NAME=appfut

# Servidor
PORT=3000

# Meta WhatsApp Business API
META_PHONE_NUMBER_ID=SEU_PHONE_NUMBER_ID
META_ACCESS_TOKEN=SEU_TOKEN_PERMANENTE
META_WEBHOOK_VERIFY_TOKEN=appfut_verify_token
