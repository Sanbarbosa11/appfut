# ============================================================
# Evolution API v2.3.5 — Piloto AppFut (AMBIENTE ISOLADO)
# ============================================================
# Copie este arquivo para .env.evolution e preencha os valores.
# .env.evolution NAO deve ser commitado (ver .gitignore).

# ---------- Servidor ----------
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://localhost:8080

# ---------- CORS ----------
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE
CORS_CREDENTIALS=true

# ---------- Log ----------
LOG_LEVEL=ERROR,WARN,INFO
LOG_COLOR=true
LOG_BAILEYS=error

# ---------- Idioma ----------
LANGUAGE=pt-BR

# ---------- Eventos globais (webhook vem na Fase 2) ----------
DEL_INSTANCE=false
DEL_TEMP_INSTANCES=false

# ---------- Banco de dados interno do Evolution (PostgreSQL, banco evolution_pg) ----------
# Container usa network_mode: host, entao 127.0.0.1 dentro do container = host do servidor
# PostgreSQL sobe via docker-compose.evolution.yml (container appfut-evolution-postgres)
# EVOLUTION_PG_PASSWORD deve ser a mesma senha definida no docker-compose
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution_pg_user:TROCAR_SENHA_PG@127.0.0.1:5432/evolution_pg
DATABASE_CONNECTION_CLIENT_NAME=evolution_exchange
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=false
DATABASE_SAVE_DATA_HISTORIC=false

# ---------- Cache (Redis DESABILITADO - workaround bug #2110) ----------
CACHE_REDIS_ENABLED=false
CACHE_LOCAL_ENABLED=true

# ---------- S3 / Storage (desabilitado no piloto) ----------
S3_ENABLED=false

# ---------- RabbitMQ / SQS / Kafka (nao usamos) ----------
RABBITMQ_ENABLED=false
SQS_ENABLED=false
KAFKA_ENABLED=false

# ---------- Websocket ----------
WEBSOCKET_ENABLED=false
WEBSOCKET_GLOBAL_EVENTS=false

# ---------- Webhook global (deixamos off - usamos webhook POR INSTANCIA) ----------
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false

# ---------- Webhook do PILOTO (Fase 2 - servidor Node local em 3002) ----------
# Porta do Express que recebe eventos do Evolution
WEBHOOK_PORT=3002
# URL que o Evolution vai chamar. Como usamos network_mode: host no container,
# 127.0.0.1:3002 do container = 127.0.0.1:3002 do host.
WEBHOOK_URL=http://127.0.0.1:3002/evolution
# Grava eventos crus em JSONL para inspecao (util na Fase 2, desligar depois)
WEBHOOK_DUMP_FILE=./webhook_events.jsonl
# Eventos que queremos receber. Lista curta para nao poluir.
# Evolution v2 suporta, entre outros:
#   MESSAGES_UPSERT, MESSAGES_UPDATE, SEND_MESSAGE,
#   CONNECTION_UPDATE, QRCODE_UPDATED,
#   GROUPS_UPSERT, GROUPS_UPDATE, GROUP_PARTICIPANTS_UPDATE,
#   PRESENCE_UPDATE, CONTACTS_UPSERT, CHATS_UPSERT
WEBHOOK_EVENTS=MESSAGES_UPSERT,CONNECTION_UPDATE,QRCODE_UPDATED,GROUP_PARTICIPANTS_UPDATE,GROUPS_UPSERT

# ---------- Piloto - instancia e numero (Fase 3) ----------
# Nome da instancia no Evolution (nao precisa ser o numero)
PILOT_INSTANCE_NAME=appfut-piloto
# Opcional: numero do chip secundario no formato 55DDDNNNNNNNN.
# Se preenchido, pedimos 'pairing code' (codigo de 8 letras p/ parear sem camera).
# Se vazio, so geramos QR code para scan.
PILOT_NUMBER=
# Onde salvar o QR como PNG (decodificado do base64 que o Evolution manda)
PILOT_QR_FILE=./qrcode.png

# ---------- Chatwoot / Typebot / Dify / OpenAI (nao usamos) ----------
CHATWOOT_ENABLED=false
TYPEBOT_ENABLED=false
OPENAI_ENABLED=false
DIFY_ENABLED=false
EVOLUTION_BOT_ENABLED=false
N8N_ENABLED=false

# ---------- Banco de dados para codigo Node ----------
# Usa o mesmo banco MySQL do bot WPP (appfut). Isso garante dados unificados.
APP_DB_HOST=127.0.0.1
APP_DB_PORT=3306
APP_DB_USER=TROCAR_USUARIO_MYSQL
APP_DB_PASSWORD=TROCAR_SENHA
APP_DB_NAME=appfut

# ---------- Numero do bot WPP/Meta (para link de boas-vindas) ----------
# Formato: 55DDDNNNNNNNNN (sem espacos, sem +)
META_BOT_NUMBER=55DDDNNNNNNNNN

# ---------- Scheduler ----------
# true = todos os crons a cada 3min (testes), false = horarios reais (producao)
SCHEDULER_MODO_TESTE=false

# ---------- PostgreSQL (senha do container evolution-postgres) ----------
# Deve ser igual a POSTGRES_PASSWORD no docker-compose.evolution.yml
EVOLUTION_PG_PASSWORD=TROCAR_SENHA_PG

# ---------- Autenticacao (chave mestre - TROCAR pela gerada) ----------
# Gerar com: openssl rand -hex 32
AUTHENTICATION_API_KEY=TROCAR_POR_CHAVE_ALEATORIA_64_CHARS

# ---------- QR Code ----------
QRCODE_LIMIT=10
QRCODE_COLOR=#198754

# ---------- Seguranca ----------
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=false

# Segredo compartilhado entre este servidor e o Evolution API.
# O Evolution envia este valor no header "apikey" de cada POST.
# O webhook_server.js rejeita requests sem este header.
# Gerar com: openssl rand -hex 32
WEBHOOK_SECRET=GERAR_COM_openssl_rand_hex_32

# JID do proprio bot (ex: 5511999999999@s.whatsapp.net).
# Usado para detectar quando o bot e removido de um grupo.
BOT_JID=55DDDNNNNNNNNN@s.whatsapp.net
